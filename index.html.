<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MDCLTS | Tienda de Camisetas</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0; padding: 0;
            background-color: #ffffff; color: #333;
        }
        header {
            text-align: center; padding: 40px 20px;
            border-bottom: 1px solid #eee;
        }
        header h1 { font-size: 2.5rem; letter-spacing: 5px; margin: 0; }
        .contact-info { margin-top: 10px; font-size: 0.9rem; color: #666; }
        
        .container {
            max-width: 1200px; margin: 20px auto; padding: 20px;
            display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }
        .product-card {
            border: 1px solid #f0f0f0; border-radius: 8px;
            padding: 15px; text-align: center; transition: transform 0.3s;
        }
        .product-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .product-card img { max-width: 100%; height: auto; border-radius: 4px; }
        .product-card h3 { margin: 15px 0 5px; font-size: 1.1rem; text-transform: uppercase; }
        .price { font-weight: bold; color: #000; font-size: 1.2rem; margin-bottom: 15px; }
        
        .btn-buy {
            display: inline-block; background-color: #25D366; color: white;
            padding: 12px 25px; text-decoration: none; border-radius: 50px;
            font-weight: bold; transition: background 0.3s;
        }
        .btn-buy:hover { background-color: #128C7E; }
        footer { text-align: center; padding: 40px; font-size: 0.8rem; color: #999; }

        @media (max-width: 600px) {
            header h1 { font-size: 1.8rem; }
            .container { gap: 15px; padding: 10px; }
        }
    </style>
</head>
<body>

<header>
    <h1>MDCLTS</h1>
    <div class="contact-info">
        Llamadas & WhatsApp: 3018942801 - 3002871131
    </div>
</header>

<div class="container">
    <div class="product-card">
        <img src="https://i.ibb.co/NdbXfF6J/IMG-20260306-WA0129.jpg" alt="Camiseta Monastery">
        <h3>Monastery Blanca y Negra</h3>
        <p class="price">$110.000 COP</p>
        <a href="https://wa.me/573018942801?text=Hola!%20Me%20interesa%20la%20camiseta%20Monastery%20Blanca%20y%20Negra" class="btn-buy">Comprar por WhatsApp</a>
    </div>

    <div class="product-card">
        <img src="https://i.ibb.co/PsqGzYpk/IMG-20260223-WA0001.jpg" alt="Camiseta Nike Azul">
        <h3>Nike Azul, Negra y Blanca</h3>
        <p class="price">$110.000 COP</p>
        <a href="https://wa.me/573018942801?text=Hola!%20Me%20interesa%20la%20camiseta%20Nike%20Azul,%20Negra%20y%20Blanca" class="btn-buy">Comprar por WhatsApp</a>
    </div>

    <div class="product-card">
        <img src="" alt="Próximamente">
        <h3>Nueva Referencia</h3>
        <p class="price">$110.000 COP</p>
        <a href="https://wa.me/573018942801?text=Hola!%20Me%20interesa%20una%20camiseta%20de%20MDCLTS" class="btn-buy">Comprar por WhatsApp</a>
    </div>
</div>

<footer>
    &copy; 2026 MDCLTS - Lorica, Córdoba.
</footer>

</body>
</html>
